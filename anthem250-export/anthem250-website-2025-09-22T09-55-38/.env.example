# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/anthem250"

# Development Settings
NODE_ENV=development
PORT=5000

# Application Settings
VITE_APP_TITLE="National Anthem 250"
VITE_APP_DESCRIPTION="First NFT of the US National Anthem commemorating America's 250th anniversary"

# Email Configuration (Optional - for contact forms)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"

# Object Storage (Optional - if using cloud storage)
OBJECT_STORAGE_BUCKET="your-bucket-name"
OBJECT_STORAGE_REGION="us-east-1"

# Social Media Integration (Optional)
TWITTER_API_KEY="your-twitter-api-key"
INSTAGRAM_ACCESS_TOKEN="your-instagram-token"

# Analytics (Optional)
GOOGLE_ANALYTICS_ID="GA-XXXXXXXXX"

# Security
JWT_SECRET="your-super-secure-jwt-secret-key"
SESSION_SECRET="your-super-secure-session-secret"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API Keys (Optional - for payment processing)
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
MOONPAY_API_KEY="your-moonpay-api-key"

# Blockchain Configuration (Optional)
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
WALLET_PRIVATE_KEY="your-wallet-private-key"

# Monitoring and Logging
LOG_LEVEL="info"
SENTRY_DSN="your-sentry-dsn"

# Cache Configuration
REDIS_URL="redis://localhost:6379"
CACHE_TTL=3600

# Feature Flags
ENABLE_CHAT_SUPPORT=true
ENABLE_SOCIAL_SHARING=true
ENABLE_ANALYTICS=true
ENABLE_EMAIL_NOTIFICATIONS=true